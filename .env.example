# Lonely Meet AI – environment variables

# ============================================================
# Google Meet
# ============================================================
MEET_URL=

# Lonely detection (seconds the participant count must stay at 1)
LONELY_THRESHOLD_SECONDS=5.0

# ============================================================
# Speech-to-Text
# ============================================================
DEEPGRAM_API_KEY=

# ============================================================
# LLM (Brain)
# ============================================================
# Provider options:
#   openai              → official OpenAI
#   anthropic           → Claude
#   ollama              → local Ollama (recommended for local)
#   openai_compatible   → LM Studio, vLLM, llama.cpp server, etc.
LLM_PROVIDER=ollama

# Model name (must match what your local server has pulled)
# Examples: llama3.1, llama3.2, qwen2.5, mistral, phi3, gemma2, etc.
LLM_MODEL=llama3.1

# Base URL for local / OpenAI-compatible servers
# Ollama (default):
LLM_BASE_URL=http://localhost:11434/v1
# LM Studio example:
# LLM_BASE_URL=http://localhost:1234/v1
# llama.cpp server example:
# LLM_BASE_URL=http://localhost:8080/v1

# API keys (only required for cloud providers)
OPENAI_API_KEY=
ANTHROPIC_API_KEY=

# Optional generation controls
LLM_TEMPERATURE=0.7
LLM_MAX_TOKENS=256

# ============================================================
# Text-to-Speech
# ============================================================
ELEVENLABS_API_KEY=
ELEVENLABS_VOICE_ID=

# ============================================================
# Persona
# ============================================================
PERSONA_NAME=gordon-ramsay
